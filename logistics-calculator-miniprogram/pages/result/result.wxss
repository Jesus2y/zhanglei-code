.result-summary {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 40rpx 30rpx;
}

.total-cost, .cost-per-item {
  text-align: center;
}

.total-cost .label, .cost-per-item .label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.total-cost .value, .cost-per-item .value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

.fee-list {
  padding: 0;
}

.fee-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.fee-item:last-child {
  border-bottom: none;
}

.fee-info {
  flex: 1;
}

.fee-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.fee-desc {
  font-size: 24rpx;
  color: #999;
}

.fee-amount {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.warnings {
  background-color: #fff7e6;
  border-left: 4rpx solid #faad14;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.warning-icon {
  margin-right: 10rpx;
}

.warning-text {
  flex: 1;
  font-size: 26rpx;
  color: #d46b08;
  line-height: 1.6;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-secondary, .btn-primary, .btn-share {
  flex: 1;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
}

.btn-primary {
  background-color: #1890ff;
  color: #fff;
}

.btn-share {
  background-color: #52c41a;
  color: #fff;
}
