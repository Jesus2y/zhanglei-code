.result-summary {
  display: flex;
  flex-direction: column;
  padding: 40rpx 30rpx;
}

.total-cost, .cost-per-item {
  text-align: center;
  margin-bottom: 20rpx;
}

.total-cost .label, .cost-per-item .label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.total-cost .value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

.cost-per-item .value {
  font-size: 28rpx;
  color: #666;
}

/* 价格区间样式 */
.price-range {
  display: flex;
  align-items: center;
  justify-content: center;
}

.price-min, .price-max {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

.price-sep {
  margin: 0 15rpx;
  font-size: 32rpx;
  color: #999;
}

.price-mid {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 需询价提示 */
.quote-notice .value {
  color: #faad14;
}
.quote-text {
  font-size: 44rpx;
  font-weight: bold;
}
.quote-hint {
  font-size: 22rpx;
  color: #d46b08;
  margin-top: 10rpx;
  line-height: 1.5;
}

/* 元信息（货物类型+时效） */
.meta-info {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  flex-wrap: wrap;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.meta-label {
  color: #999;
}

.meta-value {
  font-weight: 500;
}

.normal-tag {
  color: #52c41a;
}

.sensitive-tag {
  color: #fa8c16;
}

.delivery-time {
  color: #1890ff;
}

.fee-list {
  padding: 0;
}

.fee-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.fee-item:last-child {
  border-bottom: none;
}

.fee-info {
  flex: 1;
}

.fee-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.fee-desc {
  font-size: 24rpx;
  color: #999;
}

.fee-amount {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  text-align: right;
}

.fee-ref {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.warnings {
  background-color: #fff7e6;
  border-left: 4rpx solid #faad14;
}

.warning-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 15rpx;
}

.warning-icon {
  margin-right: 10rpx;
}

.warning-text {
  flex: 1;
  font-size: 26rpx;
  color: #d46b08;
  line-height: 1.6;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-secondary, .btn-primary, .btn-share {
  flex: 1;
  padding: 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
}

.btn-primary {
  background-color: #1890ff;
  color: #fff;
}

.btn-share {
  background-color: #52c41a;
  color: #fff;
}
