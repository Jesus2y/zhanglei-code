.user-info {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 30rpx;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.phone-number {
  margin-bottom: 10rpx;
}

.phone-text {
  font-size: 26rpx;
  color: #666;
}

.member-status {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.member-status.member {
  background-color: #ffd700;
  color: #fff;
}

.member-status.non-member {
  background-color: #f5f5f5;
  color: #999;
}

.membership-card {
  text-align: center;
  padding: 20rpx 0;
}

.price {
  font-size: 60rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-bottom: 30rpx;
}

.price .unit {
  font-size: 28rpx;
  color: #999;
}

.benefits {
  text-align: left;
  margin-bottom: 30rpx;
}

.benefit-item {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  padding-left: 10rpx;
}

.usage-info {
  display: flex;
  justify-content: space-around;
}

.usage-item {
  text-align: center;
}

.usage-item .label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.usage-item .value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

.menu-list {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
  margin-left: 10rpx;
}
