<view class="container">
  <view class="card" wx:if="{{historyList.length === 0}}">
    <view class="empty">暂无历史记录，先去计算一次吧</view>
  </view>

  <view class="card" wx:for="{{historyList}}" wx:key="id">
    <view class="row">
      <text class="label">总成本</text>
      <text wx:if="{{item.needQuote}}" class="value quote-text">需询价</text>
      <text wx:elif="{{item.totalCostMin && item.totalCostMax}}" class="value price-range-text">¥{{item.totalCostMin}}~¥{{item.totalCostMax}}</text>
      <text wx:else class="value">¥{{item.totalCost}}</text>
    </view>
    <view class="row" wx:if="{{item.deliveryTime}}">
      <text class="label">时效</text>
      <text>{{item.deliveryTime}}</text>
    </view>
    <view class="row" wx:if="{{item.goodsType}}">
      <text class="label">货物类型</text>
      <text>{{item.goodsType === 'SENSITIVE' ? '敏感货' : '普货'}}</text>
    </view>
    <view class="time">{{item.createdAt}}</view>
  </view>

  <button class="btn-secondary" wx:if="{{historyList.length > 0}}" bindtap="onClearHistory">清空历史记录</button>
</view>
