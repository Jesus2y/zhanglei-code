.empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.label {
  color: #666;
  font-size: 28rpx;
}

.value {
  color: #1890ff;
  font-size: 32rpx;
  font-weight: bold;
}

.time {
  color: #999;
  font-size: 24rpx;
  margin-top: 20rpx;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
}
